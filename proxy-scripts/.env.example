# Devin BYOK Bridge — 环境变量模板
# 复制为 .env 后填写；.env 已被 .gitignore 排除，切勿提交到 Git。
# 通常由扩展侧栏「一键启动」自动写入，本文件仅供手动参考。

# ─── BYOK #1 ───
BYOK1_ANTHROPIC_API_HOST=
BYOK1_ANTHROPIC_API_KEY=
BYOK1_ANTHROPIC_API_PATH=/v1/messages
BYOK1_OPENAI_API_HOST=
BYOK1_OPENAI_API_KEY=
BYOK1_OPENAI_API_PATH=/v1/responses
BYOK1_MODEL=
BYOK1_THINKING_EFFORT=

# ─── BYOK #2 ───
BYOK2_ANTHROPIC_API_HOST=
BYOK2_ANTHROPIC_API_KEY=
BYOK2_ANTHROPIC_API_PATH=/v1/messages
BYOK2_OPENAI_API_HOST=
BYOK2_OPENAI_API_KEY=
BYOK2_OPENAI_API_PATH=/v1/responses
BYOK2_MODEL=
BYOK2_THINKING_EFFORT=

# ─── 兼容 / 补全（镜像 BYOK #1）───
ANTHROPIC_API_HOST=
ANTHROPIC_API_KEY=
ANTHROPIC_API_PATH=/v1/messages
OPENAI_API_HOST=
OPENAI_API_KEY=
OPENAI_API_PATH=/v1/responses
DEFAULT_MODEL=
OPENAI_REASONING_EFFORT=
OPENAI_THINKING_ENABLED=

# ─── 通用 ───
HYBRID_PORT=3006
INFERENCE_PORT=3001
MAX_TOKENS=16384
COMPLETION_TIMEOUT_MS=12000
SYSTEM_PROMPT_OVERRIDE=
SYSTEM_PROMPT_PATH=

# 由扩展注入，一般无需手动填写
# PROXY_DEVICE_ID=
# PROXY_CLIENT_VERSION=

# ─── 可选（高级）───
# ADMIN_TOKEN=
# PROXY_SESSION_SECRET=
# OPENAI_ENABLE_REASONING=false
# GATEWAY_CAPABILITY_TTL_MS=3600000
# STRIP_UNSIGNED_THINKING=false
# ALLOW_UNAUTH_CONFIG_POST=true
# VOYAGE_API_KEY=
