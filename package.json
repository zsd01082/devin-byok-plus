{
  "name": "devin-byok-plus",
  "displayName": "Devin BYOK Plus",
  "description": "Devin Desktop BYOK 增强版 — 多模型路由、双槽位、思考强度控制（兼容旧版 Windsurf）",
  "version": "2.0.3",
  "publisher": "jornlin",
  "license": "MIT",
  "author": {
    "name": "jornlin",
    "url": "https://github.com/jornlin"
  },
  "contributors": [
    {
      "name": "ycx932436",
      "url": "https://github.com/ycx932436"
    }
  ],
  "scripts": {
    "test": "node --test \"test/**/*.test.mjs\"",
    "build": "node scripts/build.js",
    "package": "node scripts/package.js",
    "release": "node scripts/release.js",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\""
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "vscode": "^1.1.37"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jornlin/devin-byok-plus.git"
  },
  "homepage": "https://github.com/jornlin/devin-byok-plus",
  "bugs": {
    "url": "https://github.com/jornlin/devin-byok-plus/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "devin",
    "byok",
    "ai",
    "claude",
    "anthropic",
    "proxy",
    "multi-model"
  ],
  "icon": "resources/icons/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onView:devin-byok-plus.sidebar"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devin-byok-plus",
          "title": "Devin BYOK Plus",
          "icon": "resources/icons/icon.svg"
        }
      ]
    },
    "views": {
      "devin-byok-plus": [
        {
          "type": "webview",
          "id": "devin-byok-plus.sidebar",
          "name": "控制面板",
          "icon": "resources/icons/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "devin-byok-plus.startProxy",
        "title": "Devin BYOK Plus: 启动代理"
      },
      {
        "command": "devin-byok-plus.stopProxy",
        "title": "Devin BYOK Plus: 停止代理"
      },
      {
        "command": "devin-byok-plus.applyPatch",
        "title": "Devin BYOK Plus: 安装补丁"
      },
      {
        "command": "devin-byok-plus.revertPatch",
        "title": "Devin BYOK Plus: 还原补丁"
      },
      {
        "command": "devin-byok-plus.reloadWorkbench",
        "title": "Devin BYOK Plus: 重载窗口（补丁生效）"
      }
    ]
  }
}
